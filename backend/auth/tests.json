{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Check admin exists",
      "method": "POST",
      "path": "/",
      "body": { "action": "check_admin" },
      "expectedStatus": 200
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/",
      "body": { "action": "login", "email": "nobody@test.dev", "password": "wrong" },
      "expectedStatus": 401
    },
    {
      "name": "Register with invalid code",
      "method": "POST",
      "path": "/",
      "body": { "action": "register_with_code", "code": "INVALID", "email": "x@x.ru", "password": "123", "full_name": "Test" },
      "expectedStatus": 404
    }
  ]
}
